generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            BigInt   @id @default(autoincrement())
  publicId      String   @unique
  email         String   @unique
  password      String
  name          String
  description   String   @default("")
  birthDate     DateTime
  hasAvatar     Boolean  @default(false)
  avatarVersion Int      @default(0)
  createdAt     DateTime @default(now())
  emailVerified Boolean  @default(false)
  admin         Boolean  @default(false)

  sessions      Session[]
  verification  EmailVerification?
  passwordReset PasswordReset?

  @@index([publicId])
  @@index([email])
}

model Session {
  id    BigInt @id @default(autoincrement())
  token String @unique

  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rememberMe Boolean  @default(false)
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id    BigInt @id @default(autoincrement())
  token String @unique

  userId BigInt @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model PasswordReset {
  id BigInt @id @default(autoincrement())

  token String @unique

  userId BigInt @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Trail {
  id       BigInt @id @default(autoincrement())
  publicId String @unique

  name        String
  description String

  point    Unsupported("geometry(Point,4326)")
  address  String
  length   Float
  duration Int

  reviewCount Int @default(0)
  ratingSum   Int @default(0)

  images TrailImage[]

  @@index([publicId])
}

model TrailImage {
  id Int @id @default(autoincrement())

  trailId BigInt
  trail   Trail  @relation(fields: [trailId], references: [id], onDelete: Cascade)

  position Int
  format   String

  @@index([id, trailId])
}
