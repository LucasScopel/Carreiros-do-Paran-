generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum VisibilityLevel {
  PUBLIC
  FRIENDS
  PRIVATE
}

model User {
  id            BigInt   @id @default(autoincrement())
  publicId      String   @unique
  email         String   @unique
  password      String
  name          String
  description   String   @default("")
  birthDate     DateTime
  hasAvatar     Boolean  @default(false)
  avatarVersion Int      @default(0)
  createdAt     DateTime @default(now())
  emailVerified Boolean  @default(false)
  admin         Boolean  @default(false)

  reviewCount       Int             @default(0)
  reviewsVisibility VisibilityLevel @default(PUBLIC)

  sessions      Session[]
  reviews       Review[]
  collections   TrailCollection[]
  verification  EmailVerification?
  passwordReset PasswordReset?

  friendCount            Int             @default(0)
  friendsVisibility      VisibilityLevel @default(PUBLIC)
  sentFriendRequests     Friendship[]    @relation("FriendshipRequester")
  receivedFriendRequests Friendship[]    @relation("FriendshipReceiver")

  @@index([publicId])
  @@index([email])
}

model Session {
  id    BigInt @id @default(autoincrement())
  token String @unique

  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rememberMe Boolean  @default(false)
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id    BigInt @id @default(autoincrement())
  token String @unique

  userId BigInt @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model PasswordReset {
  id BigInt @id @default(autoincrement())

  token String @unique

  userId BigInt @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Trail {
  id       Int    @id @default(autoincrement())
  publicId String @unique

  name        String @unique
  description String

  coordinates Unsupported("geometry(Point,4326)")
  address     String
  length      Float
  duration    Int

  reviewCount   Int @default(0)
  ratingSum     Int @default(0)
  difficultySum Int @default(0)

  images      TrailImage[]
  reviews     Review[]
  collections TrailCollectionTrail[]

  @@index([publicId])
}

model TrailImage {
  id Int @id @default(autoincrement())

  trailId Int
  trail   Trail @relation(fields: [trailId], references: [id], onDelete: Cascade)

  position Int
  format   String

  @@index([id, trailId])
}

model Review {
  id Int @id @default(autoincrement())

  comment          String
  rating           Int
  difficultyRating Int
  visitDate        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trailId Int
  userId  BigInt

  trail Trail @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trailId, userId])
  @@index([trailId])
  @@index([userId])
  @@index([trailId, id(sort: Desc)])
}

model TrailCollection {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(cuid())

  name       String
  isDefault  Boolean         @default(false)
  visibility VisibilityLevel @default(PRIVATE)
  createdAt  DateTime        @default(now())

  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trails TrailCollectionTrail[]

  @@unique([userId, name])
  @@index([userId])
}

model TrailCollectionTrail {
  collectionId Int
  trailId      Int

  addedAt DateTime @default(now())

  collection TrailCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  trail      Trail           @relation(fields: [trailId], references: [id], onDelete: Cascade)

  @@id([collectionId, trailId])
  @@index([trailId])
}

model Friendship {
  id Int @id @default(autoincrement())

  requesterId BigInt
  requester   User   @relation("FriendshipRequester", fields: [requesterId], references: [id])

  receiverId BigInt
  receiver   User   @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  accepted Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([requesterId])
  @@index([receiverId])
}
